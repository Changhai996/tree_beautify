{
  "name": "tvbot",
  "version": "1.0.0",
  "description": "A high-performance, local application for phylogenetic tree visualization, annotation, and publication-ready rendering.",
  "main": "index.js",
  "scripts": {
    "start": "python start.py",
    "dev": "vite",
    "typecheck:legacy": "tsc -p tsconfig.legacy.json",
    "typecheck:strict": "tsc -p tsconfig.strict.json",
    "lint": "eslint .",
    "format": "prettier . --write",
    "test": "vitest run",
    "check": "npm run typecheck:legacy && npm run typecheck:strict && npm test && npm run build",
    "build": "npm run typecheck:legacy && vite build",
    "preview": "vite preview"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Changhai996/TVBOT_Desktop.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Changhai996/TVBOT_Desktop/issues"
  },
  "homepage": "https://github.com/Changhai996/TVBOT_Desktop#readme",
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "eslint": "^9.39.4",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "better-sqlite3": "^12.9.0",
    "detect-libc": "^2.1.2",
    "fdir": "^6.5.0",
    "lightningcss": "^1.32.0",
    "lightningcss-darwin-arm64": "^1.32.0",
    "nanoid": "^3.3.12",
    "picocolors": "^1.1.1",
    "picomatch": "^4.0.4",
    "postcss": "^8.5.14",
    "rolldown": "^1.0.0-rc.18",
    "source-map-js": "^1.2.1",
    "tinyglobby": "^0.2.16",
    "vue": "^3.5.34",
    "vue-i18n": "^11.4.2"
  }
}
